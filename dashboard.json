    {
      "id": 12,
      "type": "barchart",
      "title": "P3 · Qué distingue al éxito autónomo del esfuerzo ansioso",
      "description": "Comparación de hábitos entre el perfil 'Autónomo Exitoso' (baja asistencia, nota ≥80) y el perfil 'Ansiedad / Esfuerzo Ineficiente' (muchas horas, nota <60). El primero combina alta motivación y autoeficacia con bajo estrés.",
      "datasource": {
        "type": "postgres",
        "uid": "tpi_postgres"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "tpi_postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT 'Visitas Biblioteca / mes' AS \"Hábito\",\n  round(avg(library_visits_per_month) FILTER (\n        WHERE attendance_rate < 60 AND final_exam_score >= 80)::numeric, 2)\n        AS \"Autónomo Exitoso\",\n  round(avg(library_visits_per_month) FILTER (\n        WHERE weekly_study_hours >= 30 AND final_exam_score < 60)::numeric, 2)\n        AS \"Ansiedad / Esfuerzo Ineficiente\"\nFROM students\nUNION ALL\nSELECT 'Motivación (1-10)',\n  round(avg(motivation_score) FILTER (WHERE attendance_rate < 60 AND final_exam_score >= 80)::numeric, 2),\n  round(avg(motivation_score) FILTER (WHERE weekly_study_hours >= 30 AND final_exam_score < 60)::numeric, 2)\nFROM students\nUNION ALL\nSELECT 'Autoeficacia (1-10)',\n  round(avg(self_efficacy_score) FILTER (WHERE attendance_rate < 60 AND final_exam_score >= 80)::numeric, 2),\n  round(avg(self_efficacy_score) FILTER (WHERE weekly_study_hours >= 30 AND final_exam_score < 60)::numeric, 2)\nFROM students\nUNION ALL\nSELECT 'Nivel de Estrés (1-10)',\n  round(avg(stress_level) FILTER (WHERE attendance_rate < 60 AND final_exam_score >= 80)::numeric, 2),\n  round(avg(stress_level) FILTER (WHERE weekly_study_hours >= 30 AND final_exam_score < 60)::numeric, 2)\nFROM students;",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "xField": "Hábito",
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
