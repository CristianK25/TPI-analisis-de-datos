    {
      "id": 11,
      "type": "trend",
      "title": "P2 · La brecha digital amplía la diferencia de rendimiento",
      "description": "Nota final promedio según horas de estudio, separando por calidad de la conexión a internet. Las líneas se abren en abanico: a mejor conectividad, mayor retorno por cada hora estudiada.",
      "datasource": {
        "type": "postgres",
        "uid": "tpi_postgres"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "tpi_postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH coef AS (\n  SELECT\n    regr_slope(final_exam_score, weekly_study_hours)\n      FILTER (WHERE internet_quality < 4.5) AS s_m,\n    regr_intercept(final_exam_score, weekly_study_hours)\n      FILTER (WHERE internet_quality < 4.5) AS i_m,\n    regr_slope(final_exam_score, weekly_study_hours)\n      FILTER (WHERE internet_quality >= 4.5 AND internet_quality < 7.5) AS s_r,\n    regr_intercept(final_exam_score, weekly_study_hours)\n      FILTER (WHERE internet_quality >= 4.5 AND internet_quality < 7.5) AS i_r,\n    regr_slope(final_exam_score, weekly_study_hours)\n      FILTER (WHERE internet_quality >= 7.5) AS s_e,\n    regr_intercept(final_exam_score, weekly_study_hours)\n      FILTER (WHERE internet_quality >= 7.5) AS i_e\n  FROM students\n)\nSELECT\n  g.x AS \"Horas de estudio (semanales)\",\n  round((coef.i_m + coef.s_m * g.x)::numeric, 1) AS \"Internet Malo / Crítico (0-4.5)\",\n  round((coef.i_r + coef.s_r * g.x)::numeric, 1) AS \"Internet Regular / Bueno (4.6-7.5)\",\n  round((coef.i_e + coef.s_e * g.x)::numeric, 1) AS \"Internet Excelente (7.6-10)\"\nFROM coef, generate_series(0, 40, 2) AS g(x)\nORDER BY g.x;",
          "refId": "A"
        }
      ],
      "options": {
        "xField": "Horas de estudio (semanales)",
        "legend": {
