    {
      "id": 10,
      "type": "trend",
      "title": "P1 · El agotamiento limita el retorno del esfuerzo",
      "description": "Nota final promedio según las horas de estudio semanales, separando a los alumnos agotados (estrés ≥7 y sueño <6h) del resto. La menor pendiente del grupo agotado muestra que el desgaste reduce el beneficio de estudiar.",
      "datasource": {
        "type": "postgres",
        "uid": "tpi_postgres"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "tpi_postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH coef AS (\n  SELECT\n    regr_slope(final_exam_score, weekly_study_hours)\n      FILTER (WHERE stress_level >= 7 AND sleep_hours < 6) AS s_ag,\n    regr_intercept(final_exam_score, weekly_study_hours)\n      FILTER (WHERE stress_level >= 7 AND sleep_hours < 6) AS i_ag,\n    regr_slope(final_exam_score, weekly_study_hours)\n      FILTER (WHERE NOT (stress_level >= 7 AND sleep_hours < 6)) AS s_de,\n    regr_intercept(final_exam_score, weekly_study_hours)\n      FILTER (WHERE NOT (stress_level >= 7 AND sleep_hours < 6)) AS i_de\n  FROM students\n)\nSELECT\n  g.x AS \"Horas de estudio (semanales)\",\n  round((coef.i_ag + coef.s_ag * g.x)::numeric, 1) AS \"Agotado (estrés alto + poco sueño)\",\n  round((coef.i_de + coef.s_de * g.x)::numeric, 1) AS \"Descansado (resto)\"\nFROM coef, generate_series(0, 40, 2) AS g(x)\nORDER BY g.x;",
          "refId": "A"
        }
      ],
      "options": {
        "xField": "Horas de estudio (semanales)",
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 3,
            "pointSize": 5,
            "showPoints": "never",
            "fillOpacity": 10,
            "spanNulls": true
          },
          "unit": "none",
          "decimals": 1
