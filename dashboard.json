    {
      "id": 13,
      "type": "barchart",
      "title": "Contexto · Porcentaje de alumnos en riesgo por carrera",
      "description": "Proporción de estudiantes marcados con alerta de riesgo académico en cada carrera. Permite priorizar dónde concentrar las acciones de apoyo.",
      "datasource": {
        "type": "postgres",
        "uid": "tpi_postgres"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "tpi_postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  major_subject AS \"Carrera\",\n  round(100.0 * avg(alerta_riesgo::int)::numeric, 1) AS \"% En Riesgo\"\nFROM students\nGROUP BY 1\nORDER BY 2 DESC;",
          "refId": "A"
        }
      ],
      "options": {
